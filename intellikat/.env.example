# Intellikat — environment variables
# All values shown are placeholders. Copy to `.env` and fill in.

# ── database (shared with backend; use a dedicated `intellikat` user) ────────
INTELLIKAT_DATABASE_URL=postgresql+psycopg://intellikat:CHANGEME@localhost:5432/rekall
INTELLIKAT_DB_POOL_SIZE=5
INTELLIKAT_DB_MAX_OVERFLOW=5
INTELLIKAT_DB_APPLICATION_NAME=intellikat

# ── azure service bus ───────────────────────────────────────────────────────
INTELLIKAT_SERVICEBUS_NAMESPACE=rekall-dev
# Production: prefer managed identity (set FQNS, leave connection string unset)
INTELLIKAT_SERVICEBUS_FULLY_QUALIFIED_NAMESPACE=
# Dev / non-prod fallback:
INTELLIKAT_SERVICEBUS_CONNECTION_STRING=Endpoint=sb://...;SharedAccessKeyName=...;SharedAccessKey=...
INTELLIKAT_SERVICEBUS_TOPIC=rekall.transcript.insights
INTELLIKAT_SERVICEBUS_SUBSCRIPTION=intellikat
INTELLIKAT_SERVICEBUS_MAX_CONCURRENT_MESSAGES=4
INTELLIKAT_SERVICEBUS_MESSAGE_LOCK_RENEWAL_SECONDS=240
INTELLIKAT_SERVICEBUS_MAX_DELIVERY_COUNT=5

# ── hugging face — sentiment ────────────────────────────────────────────────
# `hosted` calls api-inference.huggingface.co; `local` loads weights into the process
INTELLIKAT_HF_MODE=hosted
INTELLIKAT_HF_TOKEN=hf_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
INTELLIKAT_HF_MODEL_ID=MarieAngeA13/Sentiment-Analysis-BERT
INTELLIKAT_HF_INFERENCE_BASE_URL=https://api-inference.huggingface.co
INTELLIKAT_HF_LOCAL_CACHE_DIR=/var/cache/intellikat/hf
INTELLIKAT_HF_LOCAL_DEVICE=auto
INTELLIKAT_HF_LOCAL_BATCH_SIZE=16
INTELLIKAT_HF_REQUEST_TIMEOUT_SECONDS=30

# ── foundry ai — summarization ──────────────────────────────────────────────
INTELLIKAT_FOUNDRY_ENDPOINT=https://your-resource.openai.azure.com/
INTELLIKAT_FOUNDRY_API_KEY=
INTELLIKAT_FOUNDRY_USE_MANAGED_IDENTITY=false
INTELLIKAT_FOUNDRY_SUMMARY_DEPLOYMENT=gpt-4o-mini
INTELLIKAT_FOUNDRY_API_VERSION=2024-10-21
INTELLIKAT_FOUNDRY_REQUEST_TIMEOUT_SECONDS=60

# ── processing knobs ────────────────────────────────────────────────────────
INTELLIKAT_MAX_INPUT_TOKENS=512
INTELLIKAT_MAX_SUMMARY_INPUT_CHARS=60000
INTELLIKAT_SENTIMENT_FAILURE_RATIO_THRESHOLD=0.25
INTELLIKAT_PROMPT_VERSION=sum-v1

# ── http (health endpoints only) ────────────────────────────────────────────
INTELLIKAT_HTTP_LISTEN=0.0.0.0:8090

# ── logging ─────────────────────────────────────────────────────────────────
INTELLIKAT_LOG_LEVEL=INFO
INTELLIKAT_LOG_FORMAT=json

# ── generic ─────────────────────────────────────────────────────────────────
INTELLIKAT_SERVICE_ENV=development
INTELLIKAT_MAX_CONCURRENT_JOBS=4
INTELLIKAT_GRACEFUL_DRAIN_SECONDS=60
INTELLIKAT_PROMPT_DIR=config/prompts
# ─── Server ───────────────────────────────────────────────────────────────────
SERVER_PORT=8080
SERVER_ENV=development          # development | production
SWAGGER_ENABLED=true            # Serve Swagger UI at /docs — set false in production
SERVER_READ_TIMEOUT=15s
SERVER_WRITE_TIMEOUT=15s
SERVER_IDLE_TIMEOUT=60s

# ─── Database ─────────────────────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_USER=rekall
DB_PASSWORD=rekall_secret
DB_NAME=rekall_db
DB_SSL_MODE=disable
DB_MAX_OPEN_CONNS=25
DB_MAX_IDLE_CONNS=5
DB_CONN_MAX_LIFETIME=5m

# ─── Logger ───────────────────────────────────────────────────────────────────
LOG_LEVEL=info                  # debug | info | warn | error
LOG_FORMAT=json                 # json | console

# ─── CORS ─────────────────────────────────────────────────────────────────────
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# ─── Meetings ─────────────────────────────────────────────────────────────────
MEETING_WAITING_TIMEOUT=10m     # Auto-end waiting meetings after this duration
MEETING_MAX_DURATION=8h         # Force-end active meetings after this duration
MEETING_CLEANUP_INTERVAL=5m     # How often the cleanup job runs

# ─── Platform admin ───────────────────────────────────────────────────────────
# Comma-separated lowercased emails granted role=admin on every server boot.
# Platform admins create organizations (POST /organizations is gated to them)
# and may intervene on any org/dept. Users currently admin but not in this
# list are demoted to "member" on each boot — the env var is the source of
# truth. Leave empty to disable platform-admin behaviour.
PLATFORM_ADMIN_EMAILS=admin@techvify.com.vn
# Optional: when set + PLATFORM_ADMIN_EMAILS, missing admin users are
# auto-created on first boot with this password. Not re-applied on later boots.
PLATFORM_ADMIN_BOOTSTRAP_PASSWORD=Admin2026!

# ─── ASR (Live captions / transcription) ─────────────────────────────────────
# Master switch. true = backend dials the asr container at boot and the
# /meetings/:code/asr-session endpoint becomes live. Hosts still need to tick
# the per-meeting "Live captions / transcription" toggle for any single
# meeting to actually start captions.
ASR_FEATURE_ENABLED=true

# Where the backend reaches the ASR control plane. `asr` is the container
# name on the docker-compose network; for host-side `go run` use
# 127.0.0.1:9090 instead.
ASR_GRPC_ADDR=asr:9090

# 32-byte HS256 secret shared between the Go backend and the asr container.
# Both sides MUST read the same value. Generated for you on the line below;
# keep it private (treat like JWT_SECRET).
ASR_TOKEN_SECRET=0478f32624e48b2cf612afa4611ff5220c675bdc395ae75669ccfdf07a98c6c1

# Browser-facing WebSocket origin the backend embeds in StartSessionResponse.
# In dev the asr container exposes :8081 on the host. In prod use wss://...
ASR_WS_URL_BASE=ws://localhost:8081

# Token lifetime knobs (server clamps to [60s, 300s] regardless).
ASR_TOKEN_DEFAULT_TTL=3m
ASR_TOKEN_MAX_TTL=5m

# Origins permitted on the WebSocket upgrade (CSV).
ASR_WS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# Circuit breaker on the Go side: trips after N consecutive UNAVAILABLE RPCs
# and stays open for the cooldown.
ASR_CIRCUIT_BREAKER_FAILURES=3
ASR_CIRCUIT_BREAKER_COOLDOWN=30s

# ─── ASR Service — server-side env vars (consumed by the C++ binary) ─────────
# Listen addresses. gRPC MUST bind to 0.0.0.0 in docker compose so the
# backend container can reach it across the bridge network.
ASR_WS_LISTEN=0.0.0.0:8081
ASR_GRPC_LISTEN=0.0.0.0:9090
ASR_METRICS_LISTEN=0.0.0.0:9091

# Dev-only escape hatch: skip the "no mTLS off loopback" guard. Set true so
# the asr container can bind gRPC off loopback without certs. NEVER set in
# production — provision real mTLS via tls.* keys instead.
ASR_ALLOW_INSECURE_GRPC=true

# Model fallback. Used when the YAML loader can't populate models.entries
# (yaml-cpp 0.8 has a known issue with the server.* subtree on this build).
# The file under ./asr/models/ must match ASR_MODEL_DEFAULT_PATH.
ASR_MODEL_DEFAULT_ID=tiny.en
ASR_MODEL_DEFAULT_PATH=/var/lib/rekall-asr/models/ggml-tiny.en.bin
ASR_MODEL_DEFAULT_LANGUAGE=en
ASR_MODEL_DEFAULT_N_THREADS=2
ASR_MODEL_DEFAULT_BEAM_SIZE=3
ASR_MODEL_DEFAULT_BEST_OF=3
ASR_MODELS_DEFAULT=tiny.en

# Streaming latency. Lower = snappier captions, higher = less CPU per
# session. Tuned for tiny.en on a laptop CPU. Drop the partial interval to
# 100 ms if you want even snappier mid-utterance updates.
ASR_SESSION_PARTIAL_EMIT_INTERVAL_MS=150
ASR_SESSION_FINAL_EMIT_MAX_LATENCY_MS=600
ASR_SESSION_AUDIO_WINDOW_SECONDS=4

# ─── ASR Engine selection (operator-driven; never user-facing) ───────────────
# `local`  → whisper.cpp in-process (production default)
# `openai` → uploads each VAD-bounded segment to OpenAI's transcription
#            endpoint via the vendored olrea/openai-cpp library. CPU-friendly
#            for dev laptops where whisper.cpp is too slow to validate the flow.
# Switching modes is a config / env / restart operation — the frontend has no
# UI to flip the engine at runtime.
#
# To compile a slim cloud-only Docker image (no whisper.cpp, ~80 MB):
#   make asr-image-openai     # → rekall-asr:openai
# To run that image, set REKALL_ASR_IMAGE_TAG=openai and ASR_ENGINE_MODE=openai.
ASR_ENGINE_MODE=openai
ASR_ALLOW_OPENAI_IN_PRODUCTION=false   # safety guard for SERVER_ENV=production
REKALL_ASR_ENGINE=both                 # CMake / Docker build-arg: local|openai|both
REKALL_ASR_IMAGE_TAG=latest            # docker-compose tag selector

# OpenAI engine — only used when ASR_ENGINE_MODE=openai. Fill OPENAI_API_KEY
# below before flipping the mode; leave it blank otherwise (validator refuses
# to start in openai mode without a key).
OPENAI_API_KEY=
# Leave blank for the default api.openai.com endpoint. If set, MUST start
# with https:// (cleartext proxies are refused).
ASR_ENGINE_OPENAI_BASE_URL=
ASR_ENGINE_OPENAI_ORGANIZATION=
ASR_ENGINE_OPENAI_MODEL=whisper-1
ASR_ENGINE_OPENAI_LANGUAGE=en
ASR_ENGINE_OPENAI_RESPONSE_FORMAT=verbose_json
ASR_ENGINE_OPENAI_REQUEST_TIMEOUT_SECONDS=30
ASR_ENGINE_OPENAI_MAX_SEGMENT_SECONDS=60
ASR_ENGINE_OPENAI_MIN_SEGMENT_SECONDS=1
ASR_ENGINE_OPENAI_RETRIES=2
ASR_ENGINE_OPENAI_RETRY_BACKOFF_MS=500

# ─── Kat — live AI meeting notes ─────────────────────────────────────────────
# Notes are NOT persisted: in-memory only for the duration of the meeting.
# When the last participant leaves (or the backend restarts), they're gone.
KAT_ENABLED=true

# Provider: "foundry" (Azure AI Foundry / Azure OpenAI) or "openai".
KAT_PROVIDER=openai

# OpenAI path (used when KAT_PROVIDER=openai). Required: api key + model.
# BaseURL is optional — leave blank for api.openai.com.
KAT_OPENAI_API_KEY=
KAT_OPENAI_MODEL=gpt-4o-mini
KAT_OPENAI_BASE_URL=

# Foundry path (used when KAT_PROVIDER=foundry). Leave KAT_FOUNDRY_API_KEY
# blank in production to use DefaultAzureCredential (managed identity).
KAT_FOUNDRY_ENDPOINT=
KAT_FOUNDRY_DEPLOYMENT=
KAT_FOUNDRY_API_VERSION=2024-08-01-preview
KAT_FOUNDRY_API_KEY=

# Sliding-window scheduler.
KAT_FOUNDRY_REQUEST_TIMEOUT_MS=15000
KAT_WINDOW_SECONDS=120
KAT_STEP_SECONDS=20
KAT_MIN_NEW_SEGMENTS=2
KAT_MAX_CONCURRENT_RUNS=4
KAT_COOLDOWN_AFTER_ERROR_SECONDS=60
KAT_RING_BUFFER_CAPACITY=20
KAT_PROMPT_VERSION=kat-v1

# ─── Frontend ─────────────────────────────────────────────────────────────────
VITE_API_BASE_URL=http://localhost:8080/api/v1

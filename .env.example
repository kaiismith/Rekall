# ─── Server ───────────────────────────────────────────────────────────────────
SERVER_PORT=8080
SERVER_ENV=development          # development | production
SWAGGER_ENABLED=true            # Serve Swagger UI at /docs — set false in production
SERVER_READ_TIMEOUT=15s
SERVER_WRITE_TIMEOUT=15s
SERVER_IDLE_TIMEOUT=60s

# ─── Database ─────────────────────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_USER=rekall
DB_PASSWORD=rekall_secret
DB_NAME=rekall_db
DB_SSL_MODE=disable
DB_MAX_OPEN_CONNS=25
DB_MAX_IDLE_CONNS=5
DB_CONN_MAX_LIFETIME=5m

# ─── Logger ───────────────────────────────────────────────────────────────────
LOG_LEVEL=info                  # debug | info | warn | error
LOG_FORMAT=json                 # json | console

# ─── CORS ─────────────────────────────────────────────────────────────────────
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# ─── Meetings ─────────────────────────────────────────────────────────────────
MEETING_WAITING_TIMEOUT=10m     # Auto-end waiting meetings after this duration
MEETING_MAX_DURATION=8h         # Force-end active meetings after this duration
MEETING_CLEANUP_INTERVAL=5m     # How often the cleanup job runs

# ─── Platform admin ───────────────────────────────────────────────────────────
# Comma-separated lowercased emails granted role=admin on every server boot.
# Platform admins create organizations (POST /organizations is gated to them)
# and may intervene on any org/dept. Users currently admin but not in this
# list are demoted to "member" on each boot — the env var is the source of
# truth. Leave empty to disable platform-admin behaviour.
PLATFORM_ADMIN_EMAILS=
# Optional: when set + PLATFORM_ADMIN_EMAILS, missing admin users are
# auto-created on first boot with this password. Not re-applied on later boots.
PLATFORM_ADMIN_BOOTSTRAP_PASSWORD=

# ─── ASR Service (C++ / whisper.cpp) ─────────────────────────────────────────
# Master switch on the Go backend. When false, /calls/:id/asr-session returns
# 503 ASR_NOT_CONFIGURED and the frontend hides the captions UI. Set true in
# environments where the asr container is deployed.
ASR_FEATURE_ENABLED=false

# Address of the gRPC control plane (host:port).
ASR_GRPC_ADDR=asr:9090

# Shared secret for signing/verifying Session_Token JWTs (HS256).
# Generate with: openssl rand -hex 32. MUST be ≥ 32 bytes. Same value on
# both Go backend and asr service. Never commit a real value.
ASR_TOKEN_SECRET=

# Token lifetime knobs. Hard-capped at 300 s by the issuer.
ASR_TOKEN_DEFAULT_TTL=3m
ASR_TOKEN_MAX_TTL=5m
ASR_TOKEN_AUDIENCE=rekall-asr
ASR_TOKEN_ISSUER=rekall-backend

# Browser-facing WebSocket URL the backend embeds in StartSessionResponse.
# Use wss:// in production. The token is appended as ?token=<jwt> by the issuer.
ASR_WS_URL_BASE=ws://localhost:8081

# Comma-separated origins permitted on the WebSocket upgrade. Production must
# set this; development falls back to wildcard only when SERVER_ENV=development.
ASR_WS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# mTLS certs for the gRPC channel (production only).
ASR_GRPC_CLIENT_CERT=
ASR_GRPC_CLIENT_KEY=
ASR_GRPC_SERVER_CA=
ASR_GRPC_SERVER_NAME=rekall-asr

# Circuit breaker on the Go side: trips after N consecutive UNAVAILABLE/timeout
# RPCs and stays open for the cooldown duration.
ASR_CIRCUIT_BREAKER_FAILURES=3
ASR_CIRCUIT_BREAKER_COOLDOWN=30s

# ─── ASR Service — server-side env vars (consumed by the C++ binary) ─────────
ASR_CONFIG_PATH=/etc/rekall-asr/config.yaml
ASR_WS_LISTEN=0.0.0.0:8081
ASR_GRPC_LISTEN=0.0.0.0:9090               # MUST be 0.0.0.0 in docker compose so
                                           # the backend container can reach it
                                           # over the bridge network
ASR_METRICS_LISTEN=0.0.0.0:9091
ASR_ALLOW_INSECURE_WS=false                # dev only
ASR_GRPC_BIND_ALL=false                    # set true to bind gRPC off loopback
ASR_ALLOW_INSECURE_GRPC=false              # DEV ONLY: skip the "no mTLS off
                                           # loopback" guard. Required for
                                           # docker-compose where the backend
                                           # dials asr:9090 across the bridge.
                                           # Provision real mTLS in prod
                                           # (ASR_GRPC_SERVER_CERT etc.) and
                                           # leave this false.
ASR_GRPC_SERVER_CERT=
ASR_GRPC_SERVER_KEY=
ASR_GRPC_CLIENT_CA=
ASR_WORKER_POOL_SIZE=                      # blank → min(8, hwconc)
ASR_LOG_LEVEL=info
ASR_LOG_FORMAT=json
ASR_MODELS_DIR=/var/lib/rekall-asr/models
ASR_DROP_PRIVS_TO=
OTEL_EXPORTER_OTLP_ENDPOINT=

# Model fallback — used when the YAML loader can't populate models.entries.
# A single model is registered from these values; the file shipped under
# ./asr/models/ must match ASR_MODEL_DEFAULT_PATH.
ASR_MODEL_DEFAULT_ID=tiny.en
ASR_MODEL_DEFAULT_PATH=/var/lib/rekall-asr/models/ggml-tiny.en.bin
ASR_MODEL_DEFAULT_LANGUAGE=en
ASR_MODEL_DEFAULT_N_THREADS=2
ASR_MODEL_DEFAULT_BEAM_SIZE=3
ASR_MODEL_DEFAULT_BEST_OF=3
ASR_MODELS_DEFAULT=tiny.en

# Streaming latency knobs — lower = snappier captions, higher = less CPU per
# session. Defaults tuned for tiny.en on a laptop CPU.
ASR_SESSION_PARTIAL_EMIT_INTERVAL_MS=150   # how often to send mid-utterance text
ASR_SESSION_FINAL_EMIT_MAX_LATENCY_MS=600  # max wait after silence before final
ASR_SESSION_AUDIO_WINDOW_SECONDS=4         # rolling window fed to whisper

# ─── ASR Engine selection (mode-switching) ────────────────────────────────────
# Pick which transcription back-end runs in the C++ asr service.
#   local   — whisper.cpp in-process. Production default.
#   openai  — uploads each VAD-bounded segment to OpenAI's
#             /v1/audio/transcriptions endpoint via the vendored
#             olrea/openai-cpp library. CPU-friendly for dev laptops; only
#             emits `final` events (no partials).
#
# To compile a slim image without whisper.cpp:
#   make asr-image-openai      → tags rekall-asr:openai
# To run that image, set:
#   REKALL_ASR_IMAGE_TAG=openai
#   ASR_ENGINE_MODE=openai
#   OPENAI_API_KEY=<your-key>
ASR_ENGINE_MODE=openai                      # local | openai (default openai)
ASR_ALLOW_OPENAI_IN_PRODUCTION=false        # safety guard for SERVER_ENV=production
REKALL_ASR_ENGINE=both                      # CMake / Docker build-arg: local|openai|both
REKALL_ASR_IMAGE_TAG=latest                 # docker-compose tag selector

# OpenAI engine — only used when ASR_ENGINE_MODE=openai.
OPENAI_API_KEY=                             # REQUIRED when mode=openai
# Leave blank for the default api.openai.com endpoint. If set, MUST start
# with https:// (cleartext proxies are refused).
ASR_ENGINE_OPENAI_BASE_URL=
ASR_ENGINE_OPENAI_ORGANIZATION=
ASR_ENGINE_OPENAI_MODEL=whisper-1
ASR_ENGINE_OPENAI_LANGUAGE=en
ASR_ENGINE_OPENAI_RESPONSE_FORMAT=verbose_json
ASR_ENGINE_OPENAI_REQUEST_TIMEOUT_SECONDS=30
ASR_ENGINE_OPENAI_MAX_SEGMENT_SECONDS=60
ASR_ENGINE_OPENAI_MIN_SEGMENT_SECONDS=1
ASR_ENGINE_OPENAI_RETRIES=2
ASR_ENGINE_OPENAI_RETRY_BACKOFF_MS=500

# ─── Frontend ─────────────────────────────────────────────────────────────────
VITE_API_BASE_URL=http://localhost:8080/api/v1

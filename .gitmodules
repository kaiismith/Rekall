[submodule "asr/third_party/whisper.cpp"]
	path = asr/third_party/whisper.cpp
	url = https://github.com/ggml-org/whisper.cpp.git
	# The version is pinned by the SHA stored in the parent commit, not by a
	# branch reference. Upstream tags v1.7.* are valid checkout points; pick
	# any tag inside the submodule with `git -C asr/third_party/whisper.cpp
	# checkout <tag>` and commit the change.

[submodule "asr/third_party/openai-cpp"]
	path = asr/third_party/openai-cpp
	url = https://github.com/olrea/openai-cpp.git
	# Header-only MIT-licensed OpenAI client. Only initialised when the build
	# includes the openai engine (REKALL_ASR_ENGINE=openai|both). Pinned by SHA
	# in the parent commit; upgrade procedure documented in asr/README.md.

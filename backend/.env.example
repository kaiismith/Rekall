# ─── Server ───────────────────────────────────────────────────────────────────
SERVER_PORT=8080
SERVER_ENV=development
# Serve Swagger UI at /docs — set to false (or omit) in production
SWAGGER_ENABLED=true
SERVER_READ_TIMEOUT=15s
SERVER_WRITE_TIMEOUT=15s
SERVER_IDLE_TIMEOUT=60s

# ─── Database ─────────────────────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_USER=rekall
DB_PASSWORD=rekall_secret
DB_NAME=rekall_db
DB_SSL_MODE=disable
DB_MAX_OPEN_CONNS=25
DB_MAX_IDLE_CONNS=5
DB_CONN_MAX_LIFETIME=5m

# ─── Logger ───────────────────────────────────────────────────────────────────
LOG_LEVEL=info
LOG_FORMAT=console

# ─── CORS ─────────────────────────────────────────────────────────────────────
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# ─── Test database (integration tests only) ───────────────────────────────────
TEST_DATABASE_URL=postgres://rekall:rekall_secret@localhost:5432/rekall_test

# ─── Auth ─────────────────────────────────────────────────────────────────────
JWT_SECRET=change-me-to-a-long-random-secret
JWT_ISSUER=rekall
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=168h
PASSWORD_RESET_TTL=1h
EMAIL_VERIFY_TTL=24h
INVITATION_TTL=168h
# Base URL used to build links in emails (no trailing slash)
APP_BASE_URL=http://localhost:5173

# ─── Platform admin ───────────────────────────────────────────────────────────
# Comma-separated list of lowercased emails granted the platform-level "admin"
# role on every server boot. Each listed user can create organizations
# (POST /api/v1/organizations is gated to platform admins) and intervene on any
# org/department as if they held the highest role. Users currently with
# role=admin whose email is NOT in this list are demoted to "member" — the env
# var is the source of truth across deployments.
# Leave empty in dev to disable platform-admin behaviour entirely.
PLATFORM_ADMIN_EMAILS=admin@techvify.com.vn

# Optional: when set together with PLATFORM_ADMIN_EMAILS, missing admin users
# are auto-created on first boot with this password. Subsequent boots do NOT
# re-apply it — rotation goes through the standard password-reset flow.
PLATFORM_ADMIN_BOOTSTRAP_PASSWORD=

# ─── SMTP ─────────────────────────────────────────────────────────────────────
# Local dev: run Mailpit via docker-compose (make up), then open http://localhost:8025
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@rekall.local
SMTP_TLS=false
# Production example (SendGrid SMTP API):
# SMTP_HOST=smtp.sendgrid.net
# SMTP_PORT=587
# SMTP_USER=apikey
# SMTP_PASSWORD=SG.xxxxxxxxxxxx
# SMTP_FROM=noreply@yourdomain.com
# SMTP_TLS=true

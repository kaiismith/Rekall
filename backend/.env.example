# ─── Server ───────────────────────────────────────────────────────────────────
SERVER_PORT=8080
SERVER_ENV=development
# Serve Swagger UI at /docs — set to false (or omit) in production
SWAGGER_ENABLED=true
SERVER_READ_TIMEOUT=15s
SERVER_WRITE_TIMEOUT=15s
SERVER_IDLE_TIMEOUT=60s

# ─── Database ─────────────────────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_USER=rekall
DB_PASSWORD=rekall_secret
DB_NAME=rekall_db
DB_SSL_MODE=disable
DB_MAX_OPEN_CONNS=25
DB_MAX_IDLE_CONNS=5
DB_CONN_MAX_LIFETIME=5m

# ─── Logger ───────────────────────────────────────────────────────────────────
LOG_LEVEL=info
LOG_FORMAT=console

# ─── CORS ─────────────────────────────────────────────────────────────────────
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# ─── Test database (integration tests only) ───────────────────────────────────
TEST_DATABASE_URL=postgres://rekall:rekall_secret@localhost:5432/rekall_test

# ─── Auth ─────────────────────────────────────────────────────────────────────
JWT_SECRET=change-me-to-a-long-random-secret
JWT_ISSUER=rekall
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=168h
PASSWORD_RESET_TTL=1h
EMAIL_VERIFY_TTL=24h
INVITATION_TTL=168h
# Base URL used to build links in emails (no trailing slash)
APP_BASE_URL=http://localhost:5173

# ─── Platform admin ───────────────────────────────────────────────────────────
# Comma-separated list of lowercased emails granted the platform-level "admin"
# role on every server boot. Each listed user can create organizations
# (POST /api/v1/organizations is gated to platform admins) and intervene on any
# org/department as if they held the highest role. Users currently with
# role=admin whose email is NOT in this list are demoted to "member" — the env
# var is the source of truth across deployments.
# Leave empty in dev to disable platform-admin behaviour entirely.
PLATFORM_ADMIN_EMAILS=

# Optional: when set together with PLATFORM_ADMIN_EMAILS, missing admin users
# are auto-created on first boot with this password. Subsequent boots do NOT
# re-apply it — rotation goes through the standard password-reset flow.
PLATFORM_ADMIN_BOOTSTRAP_PASSWORD=

# ─── SMTP ─────────────────────────────────────────────────────────────────────
# Local dev: run Mailpit via docker-compose (make up), then open http://localhost:8025
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@rekall.local
SMTP_TLS=false
# Production example (SendGrid SMTP API):
# SMTP_HOST=smtp.sendgrid.net
# SMTP_PORT=587
# SMTP_USER=apikey
# SMTP_PASSWORD=SG.xxxxxxxxxxxx
# SMTP_FROM=noreply@yourdomain.com
# SMTP_TLS=true

# ─── Kat — live AI meeting notes (powered by Azure AI Foundry) ────────────────
# Notes are NOT persisted: they live only in process memory for the duration
# of the meeting and are broadcast to participants over the meeting WS hub.
# When the last participant leaves (or the backend restarts), the notes are
# gone — there is no Kat database table, no read endpoint, no audit row.
KAT_ENABLED=true

# Provider selection: "foundry" (Azure AI Foundry / Azure OpenAI) or "openai"
# (OpenAI public API, or any OpenAI-wire-compatible endpoint via
# KAT_OPENAI_BASE_URL — vLLM, LM Studio, third-party proxies). Default is
# "foundry" for backward compatibility.
KAT_PROVIDER=openai

# ─── Foundry path (KAT_PROVIDER=foundry) ────────────────────────────────────
# Foundry endpoint + deployment. Both required when KAT_PROVIDER=foundry;
# missing values put Kat into the offline state (boot still succeeds,
# /healthz/kat returns configured=false, the frontend renders the offline
# panel).
KAT_FOUNDRY_ENDPOINT=
KAT_FOUNDRY_DEPLOYMENT=
KAT_FOUNDRY_API_VERSION=2024-08-01-preview

# Foundry auth selection:
#   - Set KAT_FOUNDRY_API_KEY for direct API-key auth (dev / CI).
#   - Leave KAT_FOUNDRY_API_KEY empty in production — the backend falls back
#     to azidentity.NewDefaultAzureCredential (env vars → workload identity →
#     managed identity → Azure CLI). Same chain intellikat-service uses.
# The API key value MUST NEVER appear in any log line.
KAT_FOUNDRY_API_KEY=

# ─── OpenAI path (KAT_PROVIDER=openai) ──────────────────────────────────────
# Required when KAT_PROVIDER=openai. The model id ("gpt-4o-mini",
# "gpt-4o", etc.) and the API key. BaseURL is optional — leave blank for
# the real OpenAI API; set to point at any OpenAI-compatible endpoint.
# Managed identity is NOT supported on this provider (api-key only).
KAT_OPENAI_API_KEY=
KAT_OPENAI_MODEL=gpt-4o-mini
KAT_OPENAI_BASE_URL=

# Per-Foundry-call deadline (milliseconds).
KAT_FOUNDRY_REQUEST_TIMEOUT_MS=15000

# Sliding-window scheduler:
#   - WindowSeconds is the prompt context (last N seconds of speech).
#   - StepSeconds is how often the ticker fires per cohort.
#   - MinNewSegments gates whether a tick produces a Foundry call (a tick that
#     finds fewer than this many new finalized segments since the last note is
#     a no-op — the cost-control valve described as "near real-time, not
#     instant" in the spec).
KAT_WINDOW_SECONDS=120
KAT_STEP_SECONDS=20
KAT_MIN_NEW_SEGMENTS=2

# Concurrency + resilience:
#   - MaxConcurrentRuns caps in-flight Foundry calls across ALL cohorts. A
#     50-meeting deploy ticking in lockstep won't fire 50 parallel requests.
#   - CooldownAfterErrorSeconds: after a Foundry failure, the cohort skips
#     ticks for this long so a flapping endpoint doesn't get hammered.
KAT_MAX_CONCURRENT_RUNS=4
KAT_COOLDOWN_AFTER_ERROR_SECONDS=60

# In-memory ring buffer used for the WS late-join replay. Capped at this many
# notes per cohort entry; oldest is FIFO-evicted past the cap. Dropped along
# with the cohort entry when the last participant leaves or the meeting ends.
KAT_RING_BUFFER_CAPACITY=20

# Prompt versioning. Stamped onto every note's WS payload so a future
# kat-v2 stays distinguishable.
KAT_PROMPT_VERSION=kat-v1

#!/usr/bin/env sh
# Rekall — frontend pre-commit hook
# Runs lint-staged + project-wide tsc --noEmit on staged frontend changes.
# Bypass with `git commit --no-verify` or `HUSKY=0 git commit`. CI re-runs
# the same checks, so a bypass cannot land on main.

REPO_ROOT="$(git rev-parse --show-toplevel)"

# Bail out cleanly if frontend/ is not present (sparse checkout, bare clone).
if [ ! -d "$REPO_ROOT/frontend" ]; then
  echo "frontend/ not present, skipping pre-commit checks"
  exit 0
fi

cd "$REPO_ROOT/frontend" || exit 1

# Step 1 — lint-staged: prettier --write + eslint --fix on staged files,
# auto-restage on success, stash-restore on failure.
# --no-install so a missing binary fails fast rather than triggering an install.
npx --no-install lint-staged
LINT_STAGED_EXIT=$?

if [ $LINT_STAGED_EXIT -ne 0 ]; then
  exit $LINT_STAGED_EXIT
fi

# Step 2 — whole-project type-check, but only when at least one staged file is
# a .ts/.tsx (a removed export breaks unstaged importers, so per-file scope
# would miss errors).
if git diff --cached --name-only --diff-filter=ACMR \
     | grep -E '^frontend/.*\.(ts|tsx)$' >/dev/null 2>&1; then
  npm run -s typecheck
  TSC_EXIT=$?
  if [ $TSC_EXIT -ne 0 ]; then
    exit $TSC_EXIT
  fi
fi

exit 0
